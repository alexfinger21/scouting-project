<!DOCTYPE HTML>
<html lang="en">

<body>
    <div id="page-holder" class="team-details-page">
        <div class="small-input-container" id="team-display-selection-container">
            <label for="team-display-selector"> <b>Select team: </b> </label>
            <select name="team-display-selector" id="team-display-selector">
                <% for(let i = 0; i < teams.length; i++) { %>
                    <%if(teams[i] == selectedTeam) {%>
                        <option selected>
                            <%= teams[i] %>
                        </option>
                    <%} else {%>
                        <option>
                            <%= teams[i] %>
                        </option>
                    <%}%>
                <% } %>
            </select>
        </div>
        <div id="team-details-tabs">
            <button <%- `class= "team-details-tab ${(selectedPage == "game-data-page" ? "selected" : "")}"`%> page="game-data-page">
                Game Data
            </button>
            <button <%- `class= "team-details-tab ${(selectedPage == "pit-data-page" ? "selected" : "")}"`%> page="pit-data-page">
                Pit Data
            </button>
            <button <%- `class= "team-details-tab ${(selectedPage == "comments-display-page" ? "selected" : "")}"`%> page="comments-display-page">
                Comments
            </button>
            <button <%- `class= "team-details-tab ${(selectedPage == "auton-display-page" ? "selected" : "")}"`%> page="auton-display-page">
                Auton
            </button>
        </div>
        <% if(selectedPage == "game-data-page") {%>
            <div id="game-data-page" class="team-details-scroller" selected>
        <% } else {%>
            <div id="game-data-page" class="team-details-scroller" style="display:none;">
        <% } %>

            <div class="team-display-table-container">
                <table class="team-display-table">
                    <thead>
                        <tr>
                            <th>Match #</th>
                            <th>Game Score</th>
                            <th>Auton</th>
                            <th>T. Fuel</th>
                            <th>T. Cycle Time</th>
                            <th>T. Stockpiling Time</th>
                            <th>T. Defense Time</th>
                            <th>End Game Climb</th>
                            <th>Scouter</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% for(let i = 0; i < teamData.length; ++i) {%>
                            <tr>
                                <td>
                                    <% const gnum=parseFloat(teamData[i].game_matchup_gm_number)-1; if(matchVideos[gnum]) { %>
                                        <a href=<%-matchVideos[gnum][1]%> target="_blank">
                                            <%= teamData[i].game_matchup_gm_number %>
                                        </a>
                                    <% } else { %>
                                        <p>
                                            <%= teamData[i].game_matchup_gm_number %>
                                        </p>
                                    <% } %>
                                </td>
                                <td>
                                    <%= teamData[i].total_game_score %>
                                </td>
                                <td>
                                    <%= (teamData[i].auton_fuel_score + (teamData[i].auton_climb_successful*15)) %>
                                </td>
                                <td>
                                    <%= teamData[i].teleop_fuel_score %>
                                </td>
                                <td>
                                    <%= (teamData[i].teleop_cycling_time/1000).toFixed(1) %>
                                </td>
                                <td>
                                    <%= (teamData[i].teleop_stockpiling_time/1000).toFixed(1) %>
                                </td>
                                <td>
                                    <%= (teamData[i].teleop_defense_time/1000).toFixed(1) %>
                                </td>
                                <td>
                                    <% if (teamData[i].endgame_climb_l1_success) { %>
                                        L1
                                    <% } else if (teamData[i].endgame_climb_l2_success) { %>
                                        L2
                                    <% } else if (teamData[i].endgame_climb_l3_success) { %>
                                        L3
                                    <% } else { %>
                                        none
                                    <% } %>
                                </td>
                                <td>
                                    <%= teamData[i].gd_um_id%>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>

            <!-- <label id="select-match" for="select-match"><b>Show Auton Path for Match:</b></label>
            <select id="auton-path-select" name="select-match">
                <% for(let i = 0; i < teamData.length; i++) { %>
                    <%if(teamData[i].game_matchup_gm_number == match) {%>
                        <option auton_path="<%=teamData[i].gd_auton_path%>" selected>
                            <%=teamData[i].game_matchup_gm_number%>
                        </option>
                    <%} else {%>
                        <option auton_path="<%=teamData[i].gd_auton_path%>" >
                            <%= teamData[i].game_matchup_gm_number %>
                        </option>
                    <%}%>
                <% } %>
            </select>
            <div class="heatmap-container">
                <div class="canvas-container">
                    <canvas id="heat-map"></canvas>
                </div>
            </div> -->

        </div>

        <% if(selectedPage == "pit-data-page") {%>
            <div id="pit-data-page" class="team-details-scroller" selected>
        <% } else {%>
            <div id="pit-data-page" class="team-details-scroller" style="display:none;">
        <% } %>
            <%
                const pitTeamName = teamInfo.tm_name || ("Team " + selectedTeam)
                const pitImages = pitScoutingData?.images || []
                const pitLastUpdated = pitScoutingData?.lastUpdated
                    ? new Date(pitScoutingData.lastUpdated).toLocaleString("en-US")
                    : "Unavailable"
                const pitGalleryAttributes = []
                for (let i = 0; i < pitImages.length; i++) {
                    pitGalleryAttributes.push(`pic${i}=\"${pitImages[i].url}\"`)
                    pitGalleryAttributes.push(`pic${i}label=\"${(pitImages[i].category || "Pit Image").replace(/"/g, "&quot;")}\"`)
                    pitGalleryAttributes.push(`pic${i}name=\"${(pitImages[i].name || "Uploaded Image").replace(/"/g, "&quot;")}\"`)
                }
            %>

            <section class="pit-hero-card">
                <div class="pit-hero-copy">
                    <p class="pit-eyebrow">Team API Pit Scouting</p>
                    <p id="pit-data-title"><%= pitTeamName %></p>
                    <p class="pit-data-subtitle">
                        <%= "Team " + selectedTeam + " - Event " + (pitScoutingData?.eventId || "Unknown") %>
                    </p>
                </div>
                <div class="pit-summary-grid">
                    <div class="pit-summary-card">
                        <span class="pit-summary-label">Rank</span>
                        <span class="pit-summary-value"><%= teamInfo.api_rank != null ? teamInfo.api_rank : "N/A" %></span>
                    </div>
                    <div class="pit-summary-card">
                        <span class="pit-summary-label">OPR / DPR</span>
                        <span class="pit-summary-value">
                            <%= (teamInfo.api_opr != null ? teamInfo.api_opr.toFixed(1) : "N/A") + " / " + (teamInfo.api_dpr != null ? teamInfo.api_dpr.toFixed(1) : "N/A") %>
                        </span>
                    </div>
                    <div class="pit-summary-card">
                        <span class="pit-summary-label">Responses</span>
                        <span class="pit-summary-value"><%= pitScoutingData?.responseCount ?? 0 %></span>
                    </div>
                    <div class="pit-summary-card">
                        <span class="pit-summary-label">Last Updated</span>
                        <span class="pit-summary-value"><%= pitLastUpdated %></span>
                    </div>
                    <div class="pit-summary-card">
                        <span class="pit-summary-label">Submitted By</span>
                        <span class="pit-summary-value"><%= pitScoutingData?.submitter || "Unavailable" %></span>
                    </div>
                    <div class="pit-summary-card">
                        <span class="pit-summary-label">Status</span>
                        <span class="pit-summary-value"><%= pitScoutingData?.status || "empty" %></span>
                    </div>
                </div>
            </section>

            <% if (pitScoutingData?.message) { %>
                <div class="pit-status-banner <%= pitScoutingData?.status === 'error' ? 'pit-status-error' : 'pit-status-neutral' %>">
                    <%= pitScoutingData.message %>
                </div>
            <% } %>

            <div class="pit-layout">
                <div class="pit-sections-column">
                    <% if (pitScoutingData?.sections?.length > 0) { %>
                        <% for (const section of pitScoutingData.sections) { %>
                            <section class="pit-section-card">
                                <div class="pit-section-header">
                                    <h3><%= section.title %></h3>
                                </div>
                                <div class="pit-field-list">
                                    <% for (const item of section.items) { %>
                                        <div class="pit-field-row">
                                            <div class="pit-field-label"><%= item.label %></div>
                                            <div class="pit-field-value">
                                                <% if (item.isList) { %>
                                                    <div class="pit-chip-list">
                                                        <% for (const chip of item.value) { %>
                                                            <span class="pit-chip"><%= chip %></span>
                                                        <% } %>
                                                    </div>
                                                <% } else if (item.isLink) { %>
                                                    <a href="<%= item.value %>" target="_blank" rel="noopener noreferrer" class="pit-link">Open Link</a>
                                                <% } else { %>
                                                    <span><%= item.value %></span>
                                                <% } %>
                                            </div>
                                        </div>
                                    <% } %>
                                </div>
                            </section>
                        <% } %>
                    <% } else { %>
                        <section class="pit-section-card pit-empty-card">
                            <div class="pit-section-header">
                                <h3>Pit Details</h3>
                            </div>
                            <p class="pit-empty-text">No current Team API pit fields are available to display for this team.</p>
                        </section>
                    <% } %>
                </div>

                <aside class="pit-gallery-column">
                    <section class="pit-section-card pit-gallery-card">
                        <div class="pit-section-header">
                            <h3>Robot Photos</h3>
                        </div>
                        <% if (pitImages.length > 0) { %>
                            <div id="team-pictures-container" class="pit-gallery-shell">
                                <button id="arrow-left" class="pit-gallery-arrow" type="button" aria-label="Previous pit image">
                                    <img src="../static/images/arrow-left.svg" alt="Previous pit image">
                                </button>
                                <div class="pit-gallery-frame">
                                    <img <%-pitGalleryAttributes.join(" ")%> num-pictures="<%= pitImages.length %>" src="<%= pitImages[0].url %>" alt="<%= pitImages[0].name || 'Pit scouting image' %>" id="team-picture">
                                    <div class="pit-gallery-meta">
                                        <p id="team-picture-category"><%= pitImages[0].category || "Pit Image" %></p>
                                        <p id="team-picture-name"><%= pitImages[0].name || "Uploaded image" %></p>
                                    </div>
                                </div>
                                <button id="arrow-right" class="pit-gallery-arrow" type="button" aria-label="Next pit image">
                                    <img src="../static/images/arrow-right.svg" alt="Next pit image">
                                </button>
                            </div>
                        <% } else { %>
                            <div class="pit-gallery-empty">
                                <p>No Team API pit images were found for this team yet.</p>
                            </div>
                        <% } %>
                    </section>
                </aside>
            </div>
        </div>

        <% if(selectedPage == "comments-display-page") {%>
            <div id="comments-display-page" class="team-details-scroller" selected>
        <% } else {%>
            <div id="comments-display-page" class="team-details-scroller" style="display:none;">
        <% } %>
            <div class="team-display-table-container">
                <table class="team-display-table">
                    <colgroup>
                        <col span="1" style="width: 10%">
                        <col span="1" style="width: 15%">
                    </colgroup>
                    <thead>
                        <tr>
                            <th>Match</th>
                            <th>Scouter</th>
                            <th>Comment</th>
                        </tr>
                    </thead>
                    <tbody>
                        <%for(let i = 0; i < comments.length; i++) { %>
                            <tr>
                                <td>
                                    <%= comments[i].game_matchup_gm_number %>
                                </td>
                                <td>
                                    <%= comments[i].gc_um_id %>
                                </td>
                                <td>
                                    <%= comments[i].gc_comment %>
                                </td>
                            </tr>
                        <%}%>
                    </tbody>
                </table>
            </div>
        </div>

        <% if(selectedPage == "auton-display-page") {%>
            <div id="auton-display-page" class="team-details-scroller" selected>
        <% } else {%>
            <div id="auton-display-page" class="team-details-scroller" style="display:none;">
        <% } %>
            <% if (autonPaths.length > 0) { %>
                <div class="auton-display-toolbar">
                    <label id="select-match" for="auton-path-select"><b>Show Auton Path for Match:</b></label>
                    <select id="auton-path-select" name="select-match">
                        <% for (let i = 0; i < autonPaths.length; i++) { %>
                            <option
                                value="<%= autonPaths[i].game_matchup_gm_number %>"
                                auton_path="<%= autonPaths[i].autonPathEncoded %>"
                                alliance_color="<%= autonPaths[i].game_matchup_gm_alliance %>"
                                <%- i === 0 ? "selected" : "" %>>
                                <%= "Match " + autonPaths[i].game_matchup_gm_number + " - " + autonPaths[i].game_matchup_gm_alliance + autonPaths[i].game_matchup_gm_alliance_position %>
                            </option>
                        <% } %>
                    </select>
                </div>
                <div class="auton-heatmap-card">
                    <div class="auton-legend" aria-label="Auton path legend">
                        <span class="auton-legend-item">
                            <!-- <span class="auton-legend-dot auton-legend-start"></span> -->
                            <span>Yellow = Shoot</span>
                        </span>
                        <span class="auton-legend-item">
                            <!-- <span class="auton-legend-dot auton-legend-end"></span> -->
                            <span>Blue = Intake</span>
                        </span>
                        <span class="auton-legend-item">
                            <!-- <span class="auton-legend-dot auton-legend-end"></span> -->
                            <span>Red = Broke</span>
                        </span>
                        <span class="auton-legend-item">
                            <!-- <span class="auton-legend-dot auton-legend-waypoint"></span> -->
                            <span>Lines = Path</span>
                        </span>
                    </div>
                    <div class="canvas-container">
                        <!-- <canvas id="heat-map"></canvas> -->
                        <canvas id="field" width="456" height="449.5"></canvas>
                    </div>
                </div>
            <% } else { %>
                <section class="pit-section-card pit-empty-card">
                    <div class="pit-section-header">
                        <h3>Auton Path</h3>
                    </div>
                    <p class="pit-empty-text">No stored autonomous paths were found in the database for this team.</p>
                </section>
            <% } %>
        </div>
    
    </div>
</body>
